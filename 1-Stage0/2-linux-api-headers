# llvmtools: Kernel Headers
# Build as cmlfs user

# In fact, installing kernel headers doesn't require LLVM=1 option
# headers_install needs rsync

# Clean the source
make mrproper

# Install kernel headers
make \
    ARCH=x86_64 \
    INSTALL_HDR_PATH=/llvmtools \
    headers_install

# Kernel headers are installed to /llvmtools/include
