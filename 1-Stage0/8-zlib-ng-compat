# llvmtools: zlib-ng
# Build and install as cmlfs

# Configure
cmake \
    -G Ninja \
    -DCMAKE_INSTALL_PREFIX=/llvmtools \
    -DCMAKE_INSTALL_LIBDIR=lib \
    -DCMAKE_BUILD_TYPE=Release \
    -DCMAKE_C_COMPILER=clang \
    -DCMAKE_CXX_COMPILER=clang+= \
    -DZLIB_COMPAT=ON \
    -DWITH_GTEST=OFF \
    ../

# Build and install to llvmtools
ninja && ninja install/strip

# Create a compability symbol link
ln -sv libz.so.1.3.1.zlib-ng /llvmtools/lib/libz.so.1.3.1
