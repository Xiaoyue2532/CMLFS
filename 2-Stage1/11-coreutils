# Stage1: Coreutils
# Build and install as cmlfs

# coreutils >= 9.7 once had build errors, 
# stating that gnulib could not compile.
# This issue also occurred in m4. 
# However, this build did not encounter such problems.
# If you do, you might consider restarting the build process, 
# as something may have gone wrong somewhere.

# Cross Compiling the configure script 
# does not does not determine the correct 
# values for the following, Set the values 
# manually: 
cat > config.cache << EOF
fu_cv_sys_stat_statfs2_bsize=no
ac_cv_func_syncfs=no
gl_cv_func_working_mkstemp=yes
gl_cv_func_working_acl_get_file=yes
EOF

# Suppress a test which on some machines can loop forever:
# sed -i '/test.lock/s/^/#/' gnulib-tests/gnulib.mk

# Configure source with clang
# CFLAGS="-lfts "
AS=clang CC=clang CXX=clang++ \
AR=llvm-ar LD=ld.lld NM=llvm-nm \
READELF=llvm-readelf RANLIB=llvm-ranlib \
SIZE=llvm-size STRIP=llvm-strip \
OBJCOPY=llvm-objcopy OBJDUMP=llvm-objdump \
./configure \
    --prefix=/llvmtools \
    --build=x86_64-pc-linux-musl \
    --host=x86_64-pc-linux-musl \
    --enable-install-program=hostname \
    --cache-file=config.cache

# Build and install to toolchain
make -j`nproc --all` && make install
