# Stage1: libarchive
# Build and install as cmlfs
# Required by elftoolchain

# Apply patch to enable xz multithreaded compression by default.
patch -Np1 -i ../patches/libarchive-chimera/filter-xz-enable-threads.patch

# Configure source
AS=clang CC=clang CXX=clang++ \
AR=llvm-ar LD=ld.lld NM=llvm-nm \
READELF=llvm-readelf RANLIB=llvm-ranlib \
SIZE=llvm-size STRIP=llvm-strip \
OBJCOPY=llvm-objcopy OBJDUMP=llvm-objdump \
./configure \
    --prefix=/llvmtools \
    --build=x86_64-pc-linux-musl \
    --host=x86_64-pc-linux-musl \
    PKG_CONFIG_PATH=/llvmtools/lib/pkgconfig \
    --without-xml2 \
    --without-nettle

# Compile and install to llvmtools
make -j`nproc --all` && make install
