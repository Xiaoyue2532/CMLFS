# Chroot: openssl
# Build & install under chroot

# Configure source with clang
# openssl-3.6.1 looks for gcc
CC=clang \
./Configure \
    --prefix=/llvmtools \
    --openssldir=/llvmtools/etc/ssl \
    --libdir=lib \
    shared \
    zlib-dynamic \
    enable-ktls

# Build and install to toolchain
make -j`nproc --all` && make install
