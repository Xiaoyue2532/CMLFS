# Chroot: Nano 
# Build under chroot
# Optional package: Text editor for convenience or trouble shooting

# Configure source with clang
./configure \
    --prefix=/llvmtools \
    --sysconfdir=/llvmtools/etc \
    --enable-color \
    --enable-nanorc \
    --enable-multibuffer

# Build and install to toolchain
make -j`nproc --all` && make install

# Copy example nano configuration file
cp -v doc/sample.nanorc /llvmtools/etc/nanorc
